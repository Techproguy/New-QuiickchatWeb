// components/figma/icon-rail.tsx
"use client"

import { MessageSquareText, Phone, Clock4, Settings } from 'lucide-react'
import type { ComponentType } from "react"

function RailButton({
icon: Icon,
active = false,
label,
}: {
icon: ComponentType<{ className?: string }>
active?: boolean
label: string
}) {
return (
  <button
    className={`relative grid h-12 w-12 place-items-center rounded-xl transition-colors ${
      active ? "bg-white ring-1 ring-black/10" : "bg-neutral-200 hover:bg-neutral-300/70"
    }`}
    aria-label={label}
  >
    {active && (
      <span className="absolute -top-1 -left-1 h-3 w-3 rounded-full bg-emerald-500 ring-2 ring-white" />
    )}
    <Icon className="h-5 w-5 text-neutral-700" />
  </button>
)
}

export function IconRail() {
return (
  <aside className="flex w-[84px] shrink-0 flex-col items-center justify-between bg-neutral-200/70 px-4 py-6">
    <div className="flex flex-col items-center gap-4">
      <RailButton icon={MessageSquareText} active label="Chats" />
      <RailButton icon={Phone} label="Calls" />
      <RailButton icon={Clock4} label="Recent" />
    </div>
    <div className="pb-1.5">
      <RailButton icon={Settings} label="Settings" />
    </div>
  </aside>
)
}
