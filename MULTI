// components/figma/chat-list.tsx
"use client"

import { Search, Users, CheckCheck } from 'lucide-react'
import { Avatar, AvatarFallback, AvatarImage } from "@/components/ui/avatar"

type Item = {
id: string
name: string
time: string
last: string
unread?: number
group?: boolean
}

const items: Item[] = [
{ id: "groups", name: "Groups", time: "11:00 pm", last: "", unread: 99, group: true },
...Array.from({ length: 7 }).map((_, i) => ({
  id: `james-${i + 1}`,
  name: "James bond",
  time: "11:00 pm",
  last: "You: okay 🙂",
})),
]

export function ChatList() {
return (
  <section className="flex w-[360px] shrink-0 flex-col bg-white">
    {/* Header */}
    <div className="px-6 pt-6">
      <h2 className="text-center text-[22px] font-semibold text-emerald-600">Chats</h2>

      {/* Search pill */}
      <div className="relative mt-4">
        <Search className="pointer-events-none absolute left-4 top-1/2 h-4 w-4 -translate-y-1/2 text-neutral-400" />
        <input
          aria-label="Search"
          placeholder="Search here"
          className="h-10 w-full rounded-full border border-neutral-300 bg-neutral-50 px-10 text-sm text-neutral-700 placeholder:text-neutral-400 outline-none focus:border-emerald-500"
        />
      </div>
    </div>

    {/* List */}
    <div className="mt-4 flex-1 overflow-y-auto">
      {items.map((it, idx) => (
        <div key={it.id} className="group border-b border-neutral-100 px-6 py-4 hover:bg-neutral-50">
          <div className="flex items-center gap-3">
            {/* Avatar or group preview */}
            {it.group ? (
              <div className="relative h-10 w-10">
                <div className="absolute -left-1 top-0 grid h-6 w-6 place-items-center rounded-full border-2 border-white bg-emerald-600">
                  <Users className="h-3.5 w-3.5 text-white" />
                </div>
                <div className="absolute left-3 top-3 flex">
                  <div className="h-3.5 w-3.5 rounded-full border-2 border-white bg-neutral-300" />
                  <div className="-ml-1.5 h-3.5 w-3.5 rounded-full border-2 border-white bg-neutral-400" />
                  <div className="-ml-1.5 h-3.5 w-3.5 rounded-full border-2 border-white bg-neutral-500" />
                </div>
              </div>
            ) : (
              <Avatar className="h-10 w-10">
                <AvatarImage src="/placeholder.svg?height=40&width=40" alt="" />
                <AvatarFallback className="text-[10px]">JB</AvatarFallback>
              </Avatar>
            )}

            <div className="min-w-0 flex-1">
              <div className="flex items-center justify-between">
                <p className="truncate text-[15px] font-medium text-neutral-900">{it.name}</p>
                <span className="ml-2 shrink-0 text-xs text-neutral-400">{it.time}</span>
              </div>
              <div className="mt-1 flex items-center justify-between">
                <div className="flex items-center gap-1 truncate text-xs text-neutral-500">
                  {!it.group && <CheckCheck className="h-3.5 w-3.5 text-emerald-500" />}
                  <span className="truncate">{idx === 0 ? "You: okay 🙂" : it.last}</span>
                </div>
                {it.unread ? (
                  <span className="ml-2 grid h-5 min-w-5 place-items-center rounded-full bg-emerald-600 px-1 text-[10px] font-semibold text-white">
                    {it.unread > 90 ? "99" : it.unread}
                  </span>
                ) : null}
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>
)
}
